# Copy this to .env and fill in values
SECRET_KEY=replace-me-with-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Databases
AUTH_DB_URL=postgresql://zap:zap@localhost:5432/zap_auth
FEED_DB_URL=postgresql://zap:zap@localhost:5432/zap_feed
GRAPH_DB_URL=postgresql://zap:zap@localhost:5432/zap_graph
MODERATION_DB_URL=postgresql://zap:zap@localhost:5432/zap_moderation
NOTIFICATION_DB_URL=postgresql://zap:zap@localhost:5432/zap_notifications
MEDIA_DB_URL=postgresql://zap:zap@localhost:5432/zap_media

# Redis
REDIS_URL=redis://localhost:6379/0

# S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=zap-media
AWS_S3_REGION=us-east-1
CDN_BASE_URL=https://cdn.yourdomain.com

# JWT
JWT_SECRET_KEY=replace-me-with-separate-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Internal service URLs (used by service clients)
AUTH_SERVICE_URL=http://auth-service:8000
FEED_SERVICE_URL=http://feed-service:8001
GRAPH_SERVICE_URL=http://graph-service:8002
MEDIA_SERVICE_URL=http://media-service:8003
MODERATION_SERVICE_URL=http://moderation-service:8004
NOTIFICATION_SERVICE_URL=http://notification-service:8005